[project]
name = "{{ name }}"
version = "0.1.0"
description = "An embedder plugin for jw-agent-toolkit."
readme = "README.md"
requires-python = ">=3.13"
license = "{{ license }}"
dependencies = [
    "jw-core{{ jw_core_version }}",
    "numpy>=1.26",
]

[project.entry-points."jw_agent_toolkit.embedders"]
{{ module }} = "{{ module }}.embedder:{{ module|capitalize }}Embedder"

[dependency-groups]
dev = [
    "pytest>=8.0",
    "ruff>=0.7",
]

[tool.ruff]
target-version = "py313"
line-length = 120

[tool.ruff.lint]
select = ["E", "F", "I", "N", "W", "UP", "B", "SIM"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ module }}"]
