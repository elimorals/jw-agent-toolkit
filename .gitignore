# Data (corpus indexado, NO commitear — pesado y/o protegido por copyright)
data/
!website/src/data/
# Source-of-truth code modules live under packages/<pkg>/src/<pkg>/data/
# and are intentionally tracked (book registries, templates, golden seeds,
# topic catalogs). These are CODE, not corpus.
!packages/**/src/**/data/
!packages/**/src/**/data/**
*.jwpub
*.epub
*.pdf
*.mp3
*.db
*.db-shm
*.db-wal

# Logs
*.log

# Secretos
.env
.env.local
.envrc.local

# Remember plugin local state (autosave logs, no necesarios en remote)
.remember/

# macOS
.DS_Store

# Python bytecode in any subdirectory
**/__pycache__/

# Cassettes are committed; sample.yaml placeholders from record_cassettes.sh
# stay around as empty files only locally — uncomment to ignore if needed:
# packages/jw-core/tests/cassettes/test_cassettes/*.yaml

.vercel

# Python venv variants created by macOS / iCloud (e.g. ".venv 2", ".venv 3")
.venv*

# jw-finetune runtime workspace (logs, events, intermediate datasets)
jw-finetune-workspace/

# Claude Code session state
.claude/
