---
import BaseLayout from "./BaseLayout.astro";
import { getLangFromUrl } from "../i18n/utils";

interface Props {
  title: string;
  description?: string;
  section?: string;
  sourcePath?: string;
  /** ISO-8601 publish/modify dates surfaced from frontmatter when present. */
  publishedTime?: string;
  modifiedTime?: string;
}

const { title, description, section, sourcePath, publishedTime, modifiedTime } =
  Astro.props;

const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";
const prefix = isEn ? "/en" : "";

const siteUrl = Astro.site ?? new URL("https://jw-agent-toolkit.vercel.app/");
const canonical = new URL(Astro.url.pathname, siteUrl).href;

// --- Schema.org: TechArticle + BreadcrumbList for this doc -------------------

const techArticle: Record<string, unknown> = {
  "@type": "TechArticle",
  "@id": canonical + "#article",
  headline: title,
  url: canonical,
  inLanguage: isEn ? "en" : "es",
  isPartOf: { "@id": new URL("/#website", siteUrl).href },
  author: { "@id": new URL("/#organization", siteUrl).href },
  publisher: { "@id": new URL("/#organization", siteUrl).href },
  mainEntityOfPage: canonical,
  ...(description ? { description } : {}),
  ...(publishedTime ? { datePublished: publishedTime } : {}),
  ...(modifiedTime ? { dateModified: modifiedTime } : {}),
};

// Build a BreadcrumbList from the URL segments. We skip the locale segment
// when present and label segments with their human-readable form.
const segments = Astro.url.pathname
  .replace(/\/$/, "")
  .split("/")
  .filter(Boolean)
  .filter((s) => s !== "en");

const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: isEn ? "Home" : "Inicio",
    item: new URL(isEn ? "/en/" : "/", siteUrl).href,
  },
];

let acc = isEn ? "/en" : "";
segments.forEach((seg, idx) => {
  acc += "/" + seg;
  breadcrumbItems.push({
    "@type": "ListItem",
    position: idx + 2,
    name: seg.replace(/[-_]/g, " "),
    item: new URL(acc, siteUrl).href,
  });
});

const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems,
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  extraJsonLd={[techArticle, breadcrumb]}
>
  <div class="mx-auto max-w-7xl px-4 pb-24 pt-10 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-[260px_1fr]">
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6 text-sm">
          <div>
            <p
              class="mb-2 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-tertiary)]"
            >
              {isEn ? "Navigation" : "Navegación"}
            </p>
            <ul class="space-y-1.5">
              <li>
                <a
                  href={`${prefix}/docs/architecture`}
                  class="text-[var(--color-ink-secondary)] hover:text-[var(--color-accent)] no-underline"
                  >{isEn ? "Architecture" : "Arquitectura"}</a
                >
              </li>
              <li>
                <a
                  href={`${prefix}/docs/vision`}
                  class="text-[var(--color-ink-secondary)] hover:text-[var(--color-accent)] no-underline"
                  >{isEn ? "Vision" : "Visión"}</a
                >
              </li>
              <li>
                <a
                  href={`${prefix}/docs/roadmap`}
                  class="text-[var(--color-ink-secondary)] hover:text-[var(--color-accent)] no-underline"
                  >{isEn ? "Roadmap" : "Hoja de ruta"}</a
                >
              </li>
            </ul>
          </div>
          <div>
            <p
              class="mb-2 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-tertiary)]"
            >
              {isEn ? "Sections" : "Secciones"}
            </p>
            <ul class="space-y-1.5">
              <li>
                <a
                  href={`${prefix}/docs#conceptos`}
                  class="text-[var(--color-ink-secondary)] hover:text-[var(--color-accent)] no-underline"
                  >{isEn ? "Concepts" : "Conceptos"}</a
                >
              </li>
              <li>
                <a
                  href={`${prefix}/docs#guias`}
                  class="text-[var(--color-ink-secondary)] hover:text-[var(--color-accent)] no-underline"
                  >{isEn ? "Guides" : "Guías"}</a
                >
              </li>
              <li>
                <a
                  href={`${prefix}/docs#referencia`}
                  class="text-[var(--color-ink-secondary)] hover:text-[var(--color-accent)] no-underline"
                  >{isEn ? "Reference" : "Referencia"}</a
                >
              </li>
            </ul>
          </div>
        </div>
      </aside>

      <article class="min-w-0">
        {
          section && (
            <p class="mb-3 font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-accent)]">
              {section}
            </p>
          )
        }
        <div class="prose">
          <slot />
        </div>

        {
          sourcePath && (
            <p class="mt-16 border-t border-[var(--color-line-subtle)] pt-6 font-mono text-[11px] text-[var(--color-ink-tertiary)]">
              {isEn ? "Edit this page on" : "Editar esta página en"}{" "}
              <a
                href={`https://github.com/elimorals/jw-agent-toolkit/edit/main/docs/${sourcePath}.md`}
                class="text-[var(--color-accent)] no-underline hover:text-[var(--color-accent-hover)]"
              >
                docs/{sourcePath}.md
              </a>
            </p>
          )
        }
      </article>
    </div>
  </div>
</BaseLayout>
