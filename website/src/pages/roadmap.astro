---
import BaseLayout from "../layouts/BaseLayout.astro";

interface PhaseRow {
  number: number;
  title: string;
  tier: string;
  status: "shipped" | "planned";
  release: "22-32" | "33-38" | "39-48" | "49-56" | "57-66" | "65-76" | "77-79";
}

const phases: PhaseRow[] = [
  // 22-32 entregadas
  { number: 22, title: "eval-doctrinal", tier: "T1 Confianza", status: "shipped", release: "22-32" },
  { number: 23, title: "citation-validator", tier: "T1 Confianza", status: "shipped", release: "22-32" },
  { number: 24, title: "study-conductor", tier: "T2 Alto valor", status: "shipped", release: "22-32" },
  { number: 25, title: "news-monitor", tier: "T2 Alto valor", status: "shipped", release: "22-32" },
  { number: 26, title: "student-parts", tier: "T3 Especializado", status: "shipped", release: "22-32" },
  { number: 27, title: "pioneer-report", tier: "T3 Especializado", status: "shipped", release: "22-32" },
  { number: 28, title: "concordance", tier: "T3 Especializado", status: "shipped", release: "22-32" },
  { number: 29, title: "letter-composer", tier: "T4 UX", status: "shipped", release: "22-32" },
  { number: 30, title: "kingdom-songs", tier: "T4 UX", status: "shipped", release: "22-32" },
  { number: 31, title: "exporter", tier: "T4 UX", status: "shipped", release: "22-32" },
  { number: 32, title: "life-topics", tier: "T4 UX", status: "shipped", release: "22-32" },
  // 33-38 entregadas
  { number: 33, title: "embed-rerank", tier: "T1 Núcleo", status: "shipped", release: "33-38" },
  { number: 34, title: "audio-premium", tier: "T1 Núcleo", status: "shipped", release: "33-38" },
  { number: 35, title: "constrained-decoding", tier: "T2 Habilitador", status: "shipped", release: "33-38" },
  { number: 36, title: "vlm-ocr", tier: "T2 Habilitador", status: "shipped", release: "33-38" },
  { number: 37, title: "colpali-visual", tier: "T3 Especializado", status: "shipped", release: "33-38" },
  { number: 38, title: "jw-gen (8º paquete)", tier: "T4 UX", status: "shipped", release: "33-38" },
  // 39-48 entregadas
  { number: 39, title: "nli-runtime", tier: "T1 Confianza runtime", status: "shipped", release: "39-48" },
  { number: 40, title: "content-provenance", tier: "T1 Confianza runtime", status: "shipped", release: "39-48" },
  { number: 41, title: "plugin-sdk", tier: "T2 Comunidad", status: "shipped", release: "39-48" },
  { number: 42, title: "scaffolding", tier: "T2 Comunidad", status: "shipped", release: "39-48" },
  { number: 43, title: "agent-tracing", tier: "T2 Comunidad", status: "shipped", release: "39-48" },
  { number: 44, title: "synth-judge", tier: "T2 Comunidad", status: "shipped", release: "39-48" },
  { number: 45, title: "semantic-chunking", tier: "T3 Frontera", status: "shipped", release: "39-48" },
  { number: 46, title: "canonical-versification", tier: "T3 Frontera", status: "shipped", release: "39-48" },
  { number: 47, title: "jw-core-js-minimal", tier: "T4 Superficie JS", status: "shipped", release: "39-48" },
  { number: 48, title: "wol-browser-ext", tier: "T4 Superficie JS", status: "shipped", release: "39-48" },
  // 49-56 entregadas — jw-core completo + bridge JS
  { number: 49, title: "second-brain", tier: "T1 Memoria persistente", status: "shipped", release: "49-56" },
  { number: 50, title: "jwpub-writer", tier: "T2 Generación", status: "shipped", release: "49-56" },
  { number: 51, title: "organized-app schemas", tier: "T2 Interop", status: "shipped", release: "49-56" },
  { number: 52, title: "jwlibrary-writer", tier: "T2 Generación", status: "shipped", release: "49-56" },
  { number: 53, title: "omnilingual-asr", tier: "T1 Multilingüe SOTA", status: "shipped", release: "49-56" },
  { number: 54, title: "nllb-translation", tier: "T1 Multilingüe SOTA", status: "shipped", release: "49-56" },
  { number: 55, title: "wire-up multilingüe", tier: "T1 Integración", status: "shipped", release: "49-56" },
  { number: 56, title: "jw-core-js close-out", tier: "T4 Superficie JS", status: "shipped", release: "49-56" },
  // 57-66 entregadas — nuevos paquetes + reunión-en-vivo + KG bíblico
  { number: 57, title: "jw-meeting-media (clean-room)", tier: "T1 Nueva capa", status: "shipped", release: "57-66" },
  { number: 58, title: "bible-knowledge-graph", tier: "T1 KG bíblico JW-puro", status: "shipped", release: "57-66" },
  { number: 61, title: "letta-memory (opt-in)", tier: "T2 Memoria persistente", status: "shipped", release: "57-66" },
  { number: 62, title: "marker-markitdown (loaders)", tier: "T2 Loaders externos", status: "shipped", release: "57-66" },
  { number: 64, title: "whisperX-asr (diarización)", tier: "T2 ASR diarizado", status: "shipped", release: "57-66" },
  { number: 66, title: "mcp-jw-brain", tier: "T3 Brain expuesto MCP", status: "shipped", release: "57-66" },
  { number: 57.14, title: "drag-and-drop UI", tier: "T4 Follow-up MVP+1", status: "shipped", release: "57-66" },
  { number: 57.15, title: "monitor externo automático", tier: "T4 Follow-up MVP+1", status: "shipped", release: "57-66" },
  { number: 57.16, title: "multi-congregación", tier: "T4 Follow-up MVP+1", status: "shipped", release: "57-66" },
  { number: 58.13, title: "place geocoords", tier: "T4 Follow-up MVP+1", status: "shipped", release: "57-66" },
  { number: 58.14, title: "headwords expansion", tier: "T4 Follow-up MVP+1", status: "shipped", release: "57-66" },
  { number: 61.8, title: "auto-recap", tier: "T4 Follow-up MVP+1", status: "shipped", release: "57-66" },
  { number: 64.7, title: "speaker names mapping", tier: "T4 Follow-up MVP+1", status: "shipped", release: "57-66" },
  // 65-76 entregadas — agéntica + multimodal + predictivo + voz familiar
  { number: 65, title: "meta-orchestrator", tier: "T1 Agéntica", status: "shipped", release: "65-76" },
  { number: 66, title: "conversation-sparring", tier: "T1 Agéntica", status: "shipped", release: "65-76" },
  { number: 67, title: "doctrinal-reasoner", tier: "T1 Agéntica", status: "shipped", release: "65-76" },
  { number: 68, title: "talk-lab", tier: "T2 Multimodal", status: "shipped", release: "65-76" },
  { number: 69, title: "broadcasting-visual-index", tier: "T2 Multimodal", status: "shipped", release: "65-76" },
  { number: 70, title: "image-quote-verifier", tier: "T2 Multimodal", status: "shipped", release: "65-76" },
  { number: 71, title: "book-camera", tier: "T2 Multimodal", status: "shipped", release: "65-76" },
  { number: 72, title: "doctrinal-drift", tier: "T3 ML predictivo", status: "shipped", release: "65-76" },
  { number: 76, title: "family-voice-clone", tier: "T4 Voz / accesibilidad", status: "shipped", release: "65-76" },
  // 77-79 entregadas — alineamiento doctrinal: principios YAML + RLAIF + DPO/ORPO
  { number: 77, title: "fidelity-principles", tier: "T1 Alineamiento", status: "shipped", release: "77-79" },
  { number: 78, title: "rlaif-pipeline", tier: "T1 Alineamiento", status: "shipped", release: "77-79" },
  { number: 79, title: "dpo-orpo-trainers", tier: "T2 Entrenamiento", status: "shipped", release: "77-79" },
];

const shippedCount = phases.filter((p) => p.status === "shipped").length;
const plannedCount = phases.filter((p) => p.status === "planned").length;

const releases = [
  {
    id: "22-32",
    title: "Release 22-32 · Ecosistema discipulado",
    description:
      "11 fases ortogonales que cierran el ciclo de discipulado activo + infraestructura de confianza inicial.",
    href: "/novedades",
    color: "text-[var(--color-accent)]",
  },
  {
    id: "33-38",
    title: "Release 33-38 · Núcleo al SOTA",
    description:
      "6 fases que suben el techo técnico: embeddings + audio + gramáticas + VLM + visual + generación. Octavo paquete (jw-gen) introducido.",
    href: "/novedades-33-48",
    color: "text-[#f0b97a]",
  },
  {
    id: "39-48",
    title: "Release 39-48 · Confianza runtime + comunidad + JS",
    description:
      "10 fases entregadas: NLI en vivo, provenance, plugin SDK, scaffolding, tracing, judge, chunking, versification, TS port y browser ext.",
    href: "/novedades-33-48",
    color: "text-[#c4a7e7]",
  },
  {
    id: "49-56",
    title: "Release 49-56 · jw-core completo + multilingüe SOTA",
    description:
      "8 fases que cierran jw-core: second-brain persistente, writers JWPUB/.jwlibrary, schemas organized-app, Omnilingual ASR (1672 idiomas), NLLB-200, wire-up multilingüe y close-out del bridge JS con CI anti-drift.",
    href: "/novedades-49-56",
    color: "text-[#7ab0e3]",
  },
  {
    id: "57-66",
    title: "Release 57-66 · 2 paquetes nuevos + reunión-en-vivo + KG bíblico",
    description:
      "13 fases en una sesión continua: jw-meeting-media clean-room (parser WOL desde DevTools + presenter Tauri), bible-knowledge-graph JW-puro (607 a.E.C.), letta-memory opt-in con Fernet, marker+markitdown loaders, whisperX diarizado + speaker mapping, brain expuesto vía MCP. Más 7 follow-ups MVP+1.",
    href: "/novedades-57-66",
    color: "text-[#5fc7dd]",
  },
  {
    id: "65-76",
    title: "Release 65-76 · Agéntica + multimodal + predictivo + voz",
    description:
      "9 fases que abren cuatro capas nuevas: orquestación agéntica con NLI crítico (F65-F67), multimodal end-to-end con cámara de libros físicos y verificador visual de citas (F68-F71), análisis diacrónico con embeddings temporales (F72) y voz familiar consentida con license gate 3-capas + cifrado Fernet (F76). +480 tests, +15 MCP tools nuevas.",
    href: "/novedades-65-76",
    color: "text-[#a4d96c]",
  },
  {
    id: "77-79",
    title: "Release 77-79 · Alineamiento al canon publicado",
    description:
      "3 fases que aplican Constitutional AI, RLAIF y DPO/ORPO al problema del fine-tune local: que no se aleje del canon publicado. F77 codifica 5 principios builtin en YAML versionado y los expone a Judge + fidelity_wrap (lazy import, cero ciclo). F78 promueve el Judge a anotador de pares e introduce SL-CAI (self-critique). F79 añade trainers DPO y ORPO con Unsloth + tres recetas Qwen3.5-0.8B (Apache-2.0) cableadas al CLI con nuevo prepare-preference. +41 tests, 1.326 passing.",
    href: "/novedades-77-79",
    color: "text-[#e898d5]",
  },
];
---

<BaseLayout
  title="Roadmap maestro — Fases 22 a 79 + follow-ups"
  description="Vista consolidada de 60 fases del jw-agent-toolkit organizadas por release (22-32 + 33-38 + 39-48 + 49-56 + 57-66 + 65-76 + 77-79) y por tier técnico. Todas entregadas: ecosistema discipulado, núcleo SOTA, confianza runtime + comunidad, multilingüe SOTA (1672 idiomas Omnilingual ASR), 2 paquetes nuevos (jw-brain, jw-meeting-media), agéntica + multimodal + predictivo + voz familiar consentida y alineamiento doctrinal con Constitutional AI + RLAIF + DPO/ORPO sobre Qwen3.5-0.8B."
>
  <section class="grid-noise relative overflow-hidden border-b border-[var(--color-line-subtle)]">
    <div class="mx-auto max-w-7xl px-4 pb-12 pt-16 sm:px-6 sm:pb-16 sm:pt-20">
      <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-ink-tertiary)]">
        <span class="inline-block h-px w-8 bg-[var(--color-accent)] align-middle"></span>
        <span class="ml-2">Roadmap maestro · {phases.length} fases</span>
      </p>
      <h1 class="mt-6 max-w-3xl text-balance font-display text-[clamp(1.85rem,5vw,3.4rem)] leading-[1.05]">
        <span class="text-[var(--color-ink-primary)]">De librería técnica a </span>
        <span class="text-[var(--color-accent)]">plataforma adoptable</span>
      </h1>
      <p class="mt-6 max-w-2xl text-[16px] leading-relaxed text-[var(--color-ink-secondary)]">
        Seis releases consecutivas que cubren <strong class="text-[var(--color-ink-primary)]">discipulado completo</strong>,
        <strong class="text-[var(--color-ink-primary)]">núcleo técnico al SOTA</strong>,
        <strong class="text-[var(--color-ink-primary)]">confianza en runtime + comunidad + frontera JS</strong>,
        <strong class="text-[var(--color-ink-primary)]">multilingüe SOTA con 1672 idiomas vía Omnilingual ASR</strong> y
        <strong class="text-[var(--color-ink-primary)]">2 paquetes nuevos con reunión-en-vivo + KG bíblico JW-puro</strong> y
        <strong class="text-[var(--color-ink-primary)]">agéntica verificable + multimodal + predictivo + voz familiar consentida</strong>.
        Mismo flujo en cada fase: brainstorming → spec aprobado → plan TDD bite-sized → implementación red-green-commit → audit.
      </p>

      <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3">
        <div class="rounded-sm border border-[var(--color-accent)]/40 bg-[var(--color-accent)]/5 p-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-accent)]">Entregadas</p>
          <p class="mt-2 font-display text-3xl text-[var(--color-ink-primary)]">{shippedCount}</p>
        </div>
        {plannedCount > 0 && (
          <div class="rounded-sm border border-[#f0b97a]/40 bg-[#f0b97a]/5 p-4">
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#f0b97a]">Planeadas</p>
            <p class="mt-2 font-display text-3xl text-[var(--color-ink-primary)]">{plannedCount}</p>
          </div>
        )}
        <div class="rounded-sm border border-[var(--color-line-subtle)] bg-[var(--color-surface-1)] p-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-tertiary)]">Total</p>
          <p class="mt-2 font-display text-3xl text-[var(--color-ink-primary)]">{phases.length}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Releases panel -->
  <section class="border-b border-[var(--color-line-subtle)]">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
      <h2 class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-ink-tertiary)]">
        ▌ 6 releases
      </h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
        {releases.map((r) => (
          <a
            href={r.href}
            class="block rounded-sm border border-[var(--color-line-subtle)] bg-[var(--color-surface-1)] p-6 no-underline transition-colors hover:border-[var(--color-line-strong)]"
          >
            <p class={`font-mono text-[11px] uppercase tracking-[0.2em] ${r.color}`}>{r.id}</p>
            <p class="mt-3 font-display text-[20px] leading-tight text-[var(--color-ink-primary)]">
              {r.title}
            </p>
            <p class="mt-3 text-[14px] leading-relaxed text-[var(--color-ink-secondary)]">
              {r.description}
            </p>
            <p class="mt-4 font-mono text-[12px] text-[var(--color-accent)]">Ver detalle →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Tabla maestra -->
  <section>
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
      <h2 class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-ink-tertiary)]">
        ▌ Tabla maestra · {phases.length} fases (22 → 76 + follow-ups)
      </h2>

      <div class="mt-6 overflow-x-auto">
        <table class="w-full border-collapse text-left font-mono text-[13px]">
          <thead>
            <tr class="border-b border-[var(--color-line)] text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-tertiary)]">
              <th class="py-3 pr-4">Fase</th>
              <th class="py-3 pr-4">Slug</th>
              <th class="py-3 pr-4">Tier</th>
              <th class="py-3 pr-4">Estado</th>
              <th class="py-3">Release</th>
            </tr>
          </thead>
          <tbody>
            {phases.map((p) => (
              <tr class="border-b border-[var(--color-line-subtle)] hover:bg-[var(--color-surface-1)]">
                <td class="py-3 pr-4 text-[var(--color-ink-primary)]">{p.number}</td>
                <td class="py-3 pr-4">
                  <code class="text-[var(--color-accent)]">{p.title}</code>
                </td>
                <td class="py-3 pr-4 text-[var(--color-ink-secondary)]">{p.tier}</td>
                <td class="py-3 pr-4">
                  {p.status === "shipped" ? (
                    <span class="inline-block rounded-sm border border-[var(--color-accent)]/40 bg-[var(--color-accent)]/5 px-2 py-0.5 text-[11px] text-[var(--color-accent)]">
                      ✓ entregada
                    </span>
                  ) : (
                    <span class="inline-block rounded-sm border border-[#f0b97a]/40 bg-[#f0b97a]/5 px-2 py-0.5 text-[11px] text-[#f0b97a]">
                      📋 planeada
                    </span>
                  )}
                </td>
                <td class="py-3 text-[var(--color-ink-secondary)]">{p.release}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="mt-8 text-[13px] leading-relaxed text-[var(--color-ink-tertiary)]">
        Cada fase planeada tiene su spec aprobado y plan TDD bite-sized en
        <code class="text-[var(--color-ink-secondary)]">docs/superpowers/specs/</code> y
        <code class="text-[var(--color-ink-secondary)]">docs/superpowers/plans/</code> respectivamente.
        Total de planning: ~92k líneas, 251 TDD tasks documentadas, paralelizables por tier.
      </p>
    </div>
  </section>

  <!-- Reglas duras -->
  <section class="border-t border-[var(--color-line-subtle)] bg-[var(--color-surface-1)]">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
      <h2 class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-ink-tertiary)]">
        ▌ Reglas duras que respetan las {phases.length} fases
      </h2>
      <ul class="mt-6 grid gap-x-10 gap-y-3 text-[14px] text-[var(--color-ink-secondary)] sm:grid-cols-2">
        <li><span class="text-[var(--color-accent)]">→</span> Sin LLM en el camino crítico — parsers/agentes/stores determinísticos.</li>
        <li><span class="text-[var(--color-accent)]">→</span> Citas siempre verificables con URL canónica a wol.jw.org.</li>
        <li><span class="text-[var(--color-accent)]">→</span> Local-first; toda persistencia personal en <code>~/.jw-agent-toolkit/</code>.</li>
        <li><span class="text-[var(--color-accent)]">→</span> No red en tests — fixtures + cassettes + injectable fetchers.</li>
        <li><span class="text-[var(--color-accent)]">→</span> Multilenguaje desde día 1 (en/es/pt mínimo, hasta 17 locales).</li>
        <li><span class="text-[var(--color-accent)]">→</span> Triple-target providers: API + GPU NVIDIA + MLX/Apple Silicon.</li>
        <li><span class="text-[var(--color-accent)]">→</span> No sustituye la palabra de los ancianos.</li>
        <li><span class="text-[var(--color-accent)]">→</span> Sin distribuir letras de cánticos ni texto bíblico (copyright).</li>
      </ul>
    </div>
  </section>
</BaseLayout>
