      "Tool MCP compose_witnessing.",
      "3 golden cases L1 (letter/phone/cart).",
    ],
    pending: [
      "Templates específicos adicionales (hoy 30 hand-written + fallback).",
      "Modo offline para sugerencias de jw_link via pub_media cache.",
