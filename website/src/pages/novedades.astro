---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Phase {
  number: number;
  tier: 1 | 2 | 3 | 4;
  title: string;
  tagline: string;
  description: string;
  whatWasDone: string[];
  pending: string[];
  tests: number;
  commits: number;
  guideHref?: string;
  status: "shipped";
}

