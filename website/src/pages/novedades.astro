const tierMeta: Record<number, { label: string; color: string; description: string }> = {
  1: {
    label: "Tier 1 · Infraestructura de confianza",
    color: "text-[var(--color-accent)] border-[var(--color-accent)]/40",
    description: "Mide y protege todo lo demás.",
  },
  2: {
    label: "Tier 2 · Alto valor recurrente",
    color: "text-[#f0b97a] border-[#f0b97a]/40",
    description: "Uso semanal por publicador.",
  },
  3: {
    label: "Tier 3 · Especializado pero único",
    color: "text-[#a8c8ff] border-[#a8c8ff]/40",
    description: "Llena huecos pedagógicos o de informe.",
  },
  4: {
    label: "Tier 4 · Capas de UX y nicho",
    color: "text-[var(--color-ink-secondary)] border-[var(--color-line)]",
    description: "Cierran el círculo de preparación y conversión.",
  },
};

const totalCommits = phases.reduce((acc, p) => acc + p.commits, 0);
const totalTests = phases.reduce((acc, p) => acc + p.tests, 0);
const tierGroups = [1, 2, 3, 4].map((t) => ({
  meta: tierMeta[t],
  phases: phases.filter((p) => p.tier === t),
}));
---

<BaseLayout
  title="Novedades — Fases 22-32"
  description="Las 11 fases entregadas en 2026-05-30: red de seguridad doctrinal, conductor de estudio, monitor de novedades, partes del estudiante, informe de precursor, concordancia exacta, compositor de predicación, cánticos, exportador, asistente de temas de vida."
>
  <!-- ───────────────────────────── Hero ───────────────────────────── -->
  <section class="grid-noise relative overflow-hidden border-b border-[var(--color-line-subtle)]">
    <div class="mx-auto max-w-7xl px-4 pb-16 pt-16 sm:px-6 sm:pb-20 sm:pt-20 lg:pb-24 lg:pt-24">
      <p class="rise rise-1 flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-ink-tertiary)]">
        <span class="inline-block h-px w-8 bg-[var(--color-accent)]"></span>
        <span>2026-05-30 · Release 22-32</span>
      </p>
      <h1 class="rise rise-2 mt-6 max-w-3xl text-balance font-display text-[clamp(1.85rem,6vw,3.8rem)] leading-[1.02]">
        <span class="text-[var(--color-ink-primary)]">11 fases. </span>
        <span class="text-[var(--color-accent)]">Un ecosistema completo</span>
        <span class="text-[var(--color-ink-primary)]"> de discipulado y confianza.</span>
      </h1>
      <p class="rise rise-3 mt-6 max-w-2xl text-[17px] leading-relaxed text-[var(--color-ink-secondary)]">
        Las Fases 22–32 cierran el ciclo de <em class="text-[var(--color-ink-primary)]">discipulado activo</em>
        (conductor de estudio, partes del estudiante, informe de precursor) y la
        <em class="text-[var(--color-ink-primary)]">infraestructura de confianza</em>
        (eval doctrinal + citation validator) que mide cada cambio. Sin LLM en el camino crítico,
        sin red en tests, citas siempre verificables.
      </p>

      <div class="rise rise-4 mt-10 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="rounded-sm border border-[var(--color-line-subtle)] bg-[var(--color-surface-1)] p-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-tertiary)]">Fases entregadas</p>
          <p class="mt-2 font-display text-3xl text-[var(--color-ink-primary)]">11</p>
          <p class="mt-1 text-[12px] text-[var(--color-ink-secondary)]">22 → 32</p>
        </div>
        <div class="rounded-sm border border-[var(--color-line-subtle)] bg-[var(--color-surface-1)] p-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-tertiary)]">Commits TDD</p>
          <p class="mt-2 font-display text-3xl text-[var(--color-accent)]">{totalCommits}</p>
          <p class="mt-1 text-[12px] text-[var(--color-ink-secondary)]">red → green → commit</p>
        </div>
        <div class="rounded-sm border border-[var(--color-line-subtle)] bg-[var(--color-surface-1)] p-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-tertiary)]">Tests nuevos</p>
          <p class="mt-2 font-display text-3xl text-[var(--color-ink-primary)]">+{totalTests}</p>
          <p class="mt-1 text-[12px] text-[var(--color-ink-secondary)]">551 → 1641 passing</p>
        </div>
        <div class="rounded-sm border border-[var(--color-line-subtle)] bg-[var(--color-surface-1)] p-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-tertiary)]">Regresiones</p>
          <p class="mt-2 font-display text-3xl text-[var(--color-ink-primary)]">0</p>
          <p class="mt-1 text-[12px] text-[var(--color-ink-secondary)]">audit 1:1 por fase</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────────── Principios ───────────────────────────── -->
  <section class="border-b border-[var(--color-line-subtle)] bg-[var(--color-surface-1)]">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
      <h2 class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-ink-tertiary)]">
        ▌ Reglas duras respetadas por las 11 fases
      </h2>
      <ul class="mt-6 grid gap-x-10 gap-y-3 text-[14px] text-[var(--color-ink-secondary)] sm:grid-cols-2">
        <li><span class="text-[var(--color-accent)]">→</span> Sin LLM en el camino crítico — parsers/agentes/stores determinísticos.</li>
        <li><span class="text-[var(--color-accent)]">→</span> Citas siempre verificables con URL canónica a wol.jw.org.</li>
        <li><span class="text-[var(--color-accent)]">→</span> Local-first; toda persistencia personal en <code>~/.jw-agent-toolkit/</code>.</li>
        <li><span class="text-[var(--color-accent)]">→</span> Sin red en tests — fixtures + cassettes + injectable fetchers.</li>
        <li><span class="text-[var(--color-accent)]">→</span> Multilenguaje desde el día 1 (en/es/pt mínimo, hasta 17 locales).</li>
        <li><span class="text-[var(--color-accent)]">→</span> No sustituye la palabra de los ancianos — los agentes orientan, no aconsejan.</li>
        <li><span class="text-[var(--color-accent)]">→</span> Sin tracker de hermanos sin opt-in explícito + cifrado E2E.</li>
        <li><span class="text-[var(--color-accent)]">→</span> Sin distribuir letras de cánticos ni texto bíblico (copyright).</li>
      </ul>
    </div>
  </section>

  <!-- ───────────────────────────── Tiers + Fases ───────────────────────────── -->
  {tierGroups.map((group) => (
    <section class="border-b border-[var(--color-line-subtle)]">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
        <div class={`mb-10 flex flex-wrap items-baseline gap-x-6 gap-y-2 border-l-2 pl-4 ${group.meta.color}`}>
          <h2 class="font-mono text-[12px] uppercase tracking-[0.2em]">{group.meta.label}</h2>
          <p class="text-[14px] text-[var(--color-ink-secondary)]">{group.meta.description}</p>
        </div>
        <div class="space-y-12">
          {group.phases.map((phase) => (
            <article class="grid gap-8 border-t border-[var(--color-line-subtle)] pt-10 lg:grid-cols-[280px_1fr]">
              <header class="space-y-3">
                <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-ink-tertiary)]">
                  Fase {phase.number}
                </p>
                <h3 class="font-display text-[26px] leading-tight text-[var(--color-ink-primary)]">
                  {phase.title}
                </h3>
                <p class="text-[14px] italic text-[var(--color-accent)]">{phase.tagline}</p>
                <div class="flex flex-wrap gap-3 pt-2 font-mono text-[11px] text-[var(--color-ink-tertiary)]">
                  <span class="rounded-sm border border-[var(--color-line-subtle)] bg-[var(--color-surface-2)] px-2 py-1">
                    +{phase.tests} tests
                  </span>
                  <span class="rounded-sm border border-[var(--color-line-subtle)] bg-[var(--color-surface-2)] px-2 py-1">
                    {phase.commits} commits
                  </span>
                  <span class="rounded-sm border border-[var(--color-accent)]/40 bg-[var(--color-accent)]/5 px-2 py-1 text-[var(--color-accent)]">
                    ✓ Shipped
                  </span>
                </div>
                {phase.guideHref && (
                  <a
                    href={phase.guideHref}
                    class="mt-3 inline-flex items-center gap-1.5 font-mono text-[12px] text-[var(--color-accent)] no-underline hover:underline"
                  >
                    Guía →
                  </a>
                )}
              </header>
              <div class="space-y-6">
                <p class="text-[15px] leading-relaxed text-[var(--color-ink-secondary)]">{phase.description}</p>
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-ink-tertiary)]">
                    Qué se entregó
                  </p>
                  <ul class="mt-3 space-y-1.5 text-[14px] leading-relaxed text-[var(--color-ink-primary)]">
                    {phase.whatWasDone.map((item) => (
                      <li class="flex gap-2">
                        <span class="mt-1 inline-block h-1 w-1 shrink-0 rounded-full bg-[var(--color-accent)]"></span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                {phase.pending.length > 0 && (
                  <div>
                    <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#f0b97a]">
                      Pendiente / siguiente PR
                    </p>
                    <ul class="mt-3 space-y-1.5 text-[14px] leading-relaxed text-[var(--color-ink-secondary)]">
                      {phase.pending.map((item) => (
                        <li class="flex gap-2">
                          <span class="mt-1 inline-block h-1 w-1 shrink-0 rounded-full bg-[#f0b97a]"></span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- ───────────────────────────── Cómo se construyeron ───────────────────────────── -->
  <section class="bg-[var(--color-surface-1)]">
