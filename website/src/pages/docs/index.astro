---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entries = await getCollection("docs");

// Group entries by top-level directory (or "raíz" for files directly in /docs)
type Group = { entries: typeof entries; label: string; description: string };
const groupMeta: Record<string, { label: string; description: string }> = {
  conceptos: {
    label: "Conceptos",
    description:
      "Glosario, decisiones de diseño, estrategia multi-idioma, inventario de endpoints y flujos end-to-end.",
  },
  guias: {
    label: "Guías",
    description:
      "Recetas prácticas paso a paso: resolver citas, indexar con RAG, conectar el MCP, fine-tuning local, integraciones.",
  },
  referencia: {
    label: "Referencia",
    description:
      "Documentación exhaustiva módulo por módulo de cada paquete: jw-core, jw-cli, jw-mcp, jw-rag, jw-agents.",
  },
  superpowers: {
    label: "Specs y planes",
    description:
      "Specs de superpoderes, planes técnicos de implementación y notas de research.",
  },
  __root__: {
    label: "Manuales",
    description:
      "Arquitectura, visión a largo plazo y hoja de ruta del proyecto.",
  },
};

const groups: Record<string, Group> = {};
for (const entry of entries) {
  const parts = entry.id.split("/");
  const key = parts.length > 1 ? parts[0]! : "__root__";
  if (!groups[key]) {
    groups[key] = { entries: [], ...groupMeta[key]! };
  }
  groups[key].entries.push(entry);
}

// Sort entries within each group by their id
for (const key of Object.keys(groups)) {
  groups[key]!.entries.sort((a, b) => a.id.localeCompare(b.id));
}

const orderedKeys = ["__root__", "guias", "conceptos", "referencia", "superpowers"];
const titleFor = (id: string) => {
  const last = id.split("/").pop() ?? id;
  return last
    .replace(/-/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());
};
---

<BaseLayout
  title="Documentación"
  description="Toda la documentación de jw-agent-toolkit: conceptos, guías, referencia exhaustiva, specs y planes."
>
  <div class="mx-auto max-w-7xl px-4 pb-24 sm:px-6">
    <header class="border-b border-[var(--color-line-subtle)] py-16 sm:py-24">
      <p
        class="mb-4 font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-accent)]"
      >
        Documentación
      </p>
      <h1
        class="max-w-3xl text-balance font-display text-[clamp(2.4rem,5vw,4.2rem)] leading-[1.02] text-[var(--color-ink-primary)]"
      >
        Todo lo que necesitas para construir
        <span
          class="italic text-[var(--color-accent)]"
          style="font-variation-settings: 'opsz' 144, 'SOFT' 80;">agentes</span
        > sobre contenido público de jw.org.
      </h1>
      <p class="mt-6 max-w-2xl text-[16px] leading-relaxed text-[var(--color-ink-secondary)]">
        Esta documentación se renderiza directamente desde los archivos{" "}
        <code class="font-mono text-[14px] text-[var(--color-accent)]">docs/**/*.md</code>{" "}
        del repositorio. Cuatro secciones, {entries.length} documentos.
      </p>
    </header>

    <div class="grid gap-16 py-20">
      {
        orderedKeys
          .filter((k) => groups[k])
          .map((key) => {
            const g = groups[key]!;
            return (
              <section id={key === "__root__" ? "manuales" : key} class="scroll-mt-24">
                <div class="mb-8 flex flex-col gap-2 border-b border-[var(--color-line-subtle)] pb-5">
                  <div class="flex items-baseline gap-4">
                    <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-ink-tertiary)]">
                      {String(orderedKeys.indexOf(key) + 1).padStart(2, "0")}
                    </span>
                    <h2 class="font-display text-[clamp(1.6rem,3vw,2.4rem)] leading-tight text-[var(--color-ink-primary)]">
                      {g.label}
                    </h2>
                    <span class="ml-auto font-mono text-[12px] text-[var(--color-ink-tertiary)]">
                      {g.entries.length} docs
                    </span>
                  </div>
                  <p class="max-w-3xl text-[14px] leading-relaxed text-[var(--color-ink-secondary)]">
                    {g.description}
                  </p>
                </div>

                <ul class="grid gap-px overflow-hidden rounded-[2px] border border-[var(--color-line-subtle)] bg-[var(--color-line-subtle)] sm:grid-cols-2">
                  {g.entries.map((entry) => (
                    <li class="bg-[var(--color-surface-1)]">
                      <a
                        href={`/docs/${entry.id}`}
                        class="group flex items-start gap-4 px-5 py-4 transition-colors hover:bg-[var(--color-surface-2)] no-underline"
                      >
                        <span class="mt-1.5 size-1.5 shrink-0 rounded-full bg-[var(--color-accent-dim)] transition-colors group-hover:bg-[var(--color-accent)]" />
                        <div class="min-w-0 flex-1">
                          <p class="truncate font-mono text-[13px] text-[var(--color-ink-primary)] group-hover:text-[var(--color-accent-hover)]">
                            {titleFor(entry.id)}
                          </p>
                          <p class="mt-0.5 truncate font-mono text-[10.5px] text-[var(--color-ink-tertiary)]">
                            docs/{entry.id}.md
                          </p>
                        </div>
                        <span
                          class="mt-0.5 text-[var(--color-ink-tertiary)] transition-colors group-hover:text-[var(--color-accent)]"
                          aria-hidden="true"
                        >
                          →
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            );
          })
      }
    </div>
  </div>
</BaseLayout>
