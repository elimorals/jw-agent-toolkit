---
// Pagefind-powered search modal. Opens on Cmd/Ctrl+K or "/", or by clicking
// the trigger in the header. The Pagefind UI bundle is generated by
// `pagefind --site dist` at the end of `npm run build`, so search only works
// after a build — `npm run dev` will show a friendly fallback.
---

<!-- Trigger button (placed by Header.astro) -->
<button
  type="button"
  data-search-trigger
  class="group inline-flex items-center gap-3 rounded-sm border border-[var(--color-line)] bg-[var(--color-surface-1)] px-3 py-1.5 font-mono text-[12px] text-[var(--color-ink-tertiary)] transition hover:border-[var(--color-line-strong)] hover:text-[var(--color-ink-secondary)]"
  aria-label="Buscar (Cmd+K)"
>
  <svg
    viewBox="0 0 24 24"
    class="size-3.5 text-[var(--color-ink-secondary)] group-hover:text-[var(--color-accent)]"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="7" />
    <path d="m21 21-4.3-4.3" />
  </svg>
  <span class="hidden sm:inline">Buscar</span>
  <kbd
    class="hidden rounded-[2px] border border-[var(--color-line)] bg-[var(--color-surface-base)] px-1.5 py-0.5 font-mono text-[10px] text-[var(--color-ink-tertiary)] sm:inline"
  >
    ⌘K
  </kbd>
</button>

<!-- Modal (rendered once at end of body) -->
<div
  id="search-modal"
  class="fixed inset-0 z-[100] hidden items-start justify-center px-4 pt-[10vh] sm:pt-[15vh]"
  role="dialog"
  aria-modal="true"
  aria-labelledby="search-title"
>
  <div
    data-search-backdrop
    class="absolute inset-0 bg-[var(--color-surface-base)]/85 backdrop-blur-sm"
  >
  </div>
  <div
    class="relative w-full max-w-2xl overflow-hidden rounded-[3px] border border-[var(--color-line-strong)] bg-[var(--color-surface-1)] shadow-[0_30px_80px_-20px_rgba(0,0,0,0.7)]"
  >
    <div
      class="flex items-center gap-3 border-b border-[var(--color-line-subtle)] px-5 py-4"
    >
      <h2
        id="search-title"
        class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-accent)]"
      >
        Buscar en jw-agent-toolkit
      </h2>
      <kbd
        class="ml-auto rounded-[2px] border border-[var(--color-line)] bg-[var(--color-surface-base)] px-1.5 py-0.5 font-mono text-[10px] text-[var(--color-ink-tertiary)]"
      >
        ESC
      </kbd>
    </div>
    <div
      id="pagefind-mount"
      class="max-h-[60vh] overflow-y-auto p-5 pagefind-themed"
    >
      <p class="font-mono text-[12.5px] text-[var(--color-ink-tertiary)]">
        Cargando índice de búsqueda…
      </p>
    </div>
  </div>
</div>

<script>
  /* Pagefind UI uses a runtime bundle generated post-build. We lazy-load it
     when the modal opens — that keeps the homepage shell small. */
  (function () {
    const trigger = document.querySelector<HTMLButtonElement>(
      "[data-search-trigger]",
    );
    const modal = document.getElementById("search-modal");
    const mount = document.getElementById("pagefind-mount");
    const backdrop = document.querySelector("[data-search-backdrop]");
    if (!trigger || !modal || !mount) return;

    let loaded = false;

    const open = async () => {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";

      if (loaded) {
        const input = modal.querySelector<HTMLInputElement>(
          "input.pagefind-ui__search-input",
        );
        input?.focus();
        return;
      }

      try {
        // Load Pagefind UI via runtime <script> + <link> tags. We can't
        // use dynamic import() because Rollup tries to resolve the path
        // at build time, but pagefind's bundle is generated AFTER astro
        // build by `pagefind --site dist` in the same script.
        await new Promise<void>((resolve, reject) => {
          if (document.querySelector('script[data-pagefind="ui"]')) {
            resolve();
            return;
          }
          const css = document.createElement("link");
          css.rel = "stylesheet";
          css.href = "/pagefind/pagefind-ui.css";
          document.head.appendChild(css);

          const s = document.createElement("script");
          s.src = "/pagefind/pagefind-ui.js";
          s.dataset.pagefind = "ui";
          s.onload = () => resolve();
          s.onerror = () => reject(new Error("Pagefind not built"));
          document.head.appendChild(s);
        });

        // @ts-expect-error PagefindUI is attached to window by the script.
        new window.PagefindUI({
          element: "#pagefind-mount",
          showSubResults: true,
          showImages: false,
          excerptLength: 18,
          resetStyles: false,
          translations: {
            placeholder: "Buscar guías, paquetes, referencia…",
            zero_results: "No hay resultados para [SEARCH_TERM]",
            many_results: "[COUNT] resultados para [SEARCH_TERM]",
            one_result: "1 resultado para [SEARCH_TERM]",
            searching: "Buscando…",
            clear_search: "Limpiar",
          },
        });
        loaded = true;
        window.setTimeout(() => {
          const input = modal.querySelector<HTMLInputElement>(
            "input.pagefind-ui__search-input",
          );
          input?.focus();
        }, 40);
      } catch {
        // No untrusted input here, but we build the DOM tree explicitly
        // instead of using innerHTML to keep static analyzers happy.
        while (mount.firstChild) mount.removeChild(mount.firstChild);
        const wrap = document.createElement("div");
        wrap.className =
          "space-y-3 font-mono text-[12.5px] text-[var(--color-ink-secondary)]";
        const p1 = document.createElement("p");
        p1.className = "text-[var(--color-warm)]";
        p1.textContent = "⚠ Búsqueda no disponible en modo dev.";
        const p2 = document.createElement("p");
        p2.append(
          "El índice de Pagefind se genera al hacer ",
          Object.assign(document.createElement("code"), {
            className: "text-[var(--color-accent)]",
            textContent: "npm run build",
          }),
          ".",
        );
        const p3 = document.createElement("p");
        p3.append(
          "Para probarla localmente: ",
          Object.assign(document.createElement("code"), {
            className: "text-[var(--color-accent)]",
            textContent: "npm run build && npm run preview",
          }),
        );
        wrap.append(p1, p2, p3);
        mount.appendChild(wrap);
      }
    };

    const close = () => {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
    };

    trigger.addEventListener("click", open);
    backdrop?.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      const isOpen = !modal.classList.contains("hidden");
      const target = e.target as HTMLElement | null;
      const inField =
        target &&
        (target.tagName === "INPUT" ||
          target.tagName === "TEXTAREA" ||
          target.isContentEditable);

      if (e.key === "Escape" && isOpen) {
        close();
      } else if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        isOpen ? close() : open();
      } else if (e.key === "/" && !isOpen && !inField) {
        e.preventDefault();
        open();
      }
    });
  })();
</script>

<style is:global>
  /* Theme the Pagefind default UI to match our tokens. */
  .pagefind-themed {
    --pagefind-ui-scale: 0.85;
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-ink-primary);
    --pagefind-ui-background: var(--color-surface-1);
    --pagefind-ui-border: var(--color-line);
    --pagefind-ui-tag: var(--color-surface-2);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 2px;
    --pagefind-ui-image-border-radius: 2px;
    --pagefind-ui-font: var(--font-body);
  }
  .pagefind-themed .pagefind-ui__search-input {
    font-family: var(--font-body);
    background: var(--color-surface-2);
    color: var(--color-ink-primary);
  }
  .pagefind-themed .pagefind-ui__result-title {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .pagefind-themed .pagefind-ui__result-tags {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .pagefind-themed .pagefind-ui__result-excerpt mark {
    background: rgba(95, 199, 221, 0.18);
    color: var(--color-accent);
  }
</style>
