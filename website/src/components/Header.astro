---
import Search from "./Search.astro";
import LanguageSelector from "./LanguageSelector.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const path = Astro.url.pathname;

const nav = [
  { href: lang === 'es' ? "/" : "/en", label: t("nav.home"), match: lang === 'es' ? "/" : "/en" },
  { href: lang === 'es' ? "/#paquetes" : "/en/#paquetes", label: t("nav.packages"), match: "/#paquetes" },
  { href: lang === 'es' ? "/roadmap" : "/en/roadmap", label: lang === 'es' ? "Roadmap" : "Roadmap", match: lang === 'es' ? "/roadmap" : "/en/roadmap" },
  { href: lang === 'es' ? "/novedades-33-48" : "/en/whats-new-33-48", label: t("nav.changelog"), match: lang === 'es' ? "/novedades-33-48" : "/en/whats-new-33-48" },
  { href: lang === 'es' ? "/docs" : "/en/docs", label: t("nav.docs"), match: "/docs" },
  { href: lang === 'es' ? "/docs/vision" : "/en/docs/vision", label: t("nav.vision"), match: "/docs/vision" },
];

const isActive = (href: string) => {
  const normalizedPath = path.replace(/\/$/, "");
  const normalizedHref = href.replace(/\/$/, "");
  if (normalizedHref === "" || normalizedHref === "/en") return normalizedPath === "" || normalizedPath === "/en";
  return path.includes(normalizedHref.split('#')[0]);
};
---

<header
  class="sticky top-0 z-40 border-b border-[var(--color-line-subtle)] bg-[var(--color-surface-base)]/85 backdrop-blur-md"
>
  <div
    class="mx-auto flex max-w-7xl items-center gap-3 px-3 py-3 sm:gap-6 sm:px-6 sm:py-3.5"
  >
    <a
      href="/"
      class="group flex shrink-0 items-center gap-2 no-underline sm:gap-2.5"
      aria-label="Inicio"
    >
      <span
        class="grid size-8 place-items-center rounded-[3px] bg-[var(--color-accent)] font-mono text-[12px] font-medium leading-none text-[var(--color-surface-base)] transition-transform group-hover:rotate-[-3deg] sm:size-9 sm:text-[13px]"
        aria-hidden="true"
      >
        ⌘
      </span>
      <span class="flex flex-col leading-[1.05]">
        <span
          class="whitespace-nowrap font-mono text-[12px] font-medium tracking-tight text-[var(--color-ink-primary)] sm:text-[14px]"
        >
          jw-agent-toolkit
        </span>
        <span
          class="hidden font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--color-ink-tertiary)] sm:inline"
        >
          v0.1 · GPL-3.0
        </span>
      </span>
    </a>

    <nav class="ml-auto hidden items-center gap-1 md:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "rounded-sm px-3 py-1.5 text-[13px] font-medium tracking-wide transition-colors no-underline",
              isActive(item.href)
                ? "text-[var(--color-accent)]"
                : "text-[var(--color-ink-secondary)] hover:text-[var(--color-ink-primary)]",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="ml-auto flex shrink-0 items-center gap-1.5 sm:gap-2 md:ml-0">
      <LanguageSelector />
      <Search />
      <a
        href="https://github.com/elimorals/jw-agent-toolkit"
        target="_blank"
        rel="noopener"
        aria-label="GitHub"
        class="group inline-flex items-center gap-1.5 rounded-sm border border-[var(--color-line)] bg-[var(--color-surface-1)] px-2.5 py-1.5 font-mono text-[12px] text-[var(--color-ink-secondary)] transition hover:border-[var(--color-line-strong)] hover:text-[var(--color-ink-primary)] no-underline sm:px-3"
      >
        <svg
          viewBox="0 0 24 24"
          class="size-3.5"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-1.94c-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.05 11.05 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .3.21.66.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"
          ></path>
        </svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
      <button
        type="button"
        class="grid size-8 shrink-0 place-items-center rounded-sm border border-[var(--color-line)] text-[var(--color-ink-secondary)] transition hover:text-[var(--color-ink-primary)] md:hidden"
        aria-label="Menú"
        data-mobile-toggle
      >
        <svg
          viewBox="0 0 24 24"
          class="size-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-nav"
    class="hidden border-t border-[var(--color-line-subtle)] bg-[var(--color-surface-1)] px-4 py-2 md:hidden"
  >
    {
      nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "block px-2 py-2 text-sm transition-colors no-underline",
            isActive(item.href)
              ? "text-[var(--color-accent)]"
              : "text-[var(--color-ink-secondary)]",
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(
    "[data-mobile-toggle]",
  );
  const menu = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
