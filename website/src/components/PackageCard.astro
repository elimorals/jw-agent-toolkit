---
interface Props {
  name: string;
  tagline: string;
  description: string;
  highlights: string[];
  href: string;
  index: number;
}

const { name, tagline, description, highlights, href, index } = Astro.props;
const num = String(index).padStart(2, "0");
---

<a
  href={href}
  class="group card-hover relative flex flex-col gap-5 rounded-[var(--radius-card)] border border-[var(--color-line-subtle)] bg-[var(--color-surface-1)] p-6 no-underline"
>
  <div class="flex items-start justify-between gap-4">
    <div class="space-y-1">
      <span
        class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-ink-tertiary)]"
      >
        Paquete · {num}
      </span>
      <h3
        class="font-mono text-[18px] font-medium leading-tight text-[var(--color-ink-primary)]"
      >
        {name}
      </h3>
      <p
        class="text-[13px] italic text-[var(--color-accent)]"
        style="font-family: var(--font-display); font-weight: 400;"
      >
        {tagline}
      </p>
    </div>
    <svg
      viewBox="0 0 24 24"
      class="mt-1 size-4 shrink-0 text-[var(--color-ink-tertiary)] transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-[var(--color-accent)]"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M7 17L17 7M9 7h8v8" />
    </svg>
  </div>

  <p class="text-sm leading-relaxed text-[var(--color-ink-secondary)]">
    {description}
  </p>

  <ul class="mt-auto space-y-1.5 border-t border-[var(--color-line-subtle)] pt-4">
    {
      highlights.map((h) => (
        <li class="flex items-start gap-2 text-[12px] text-[var(--color-ink-tertiary)]">
          <span class="mt-2 inline-block size-1 shrink-0 rounded-full bg-[var(--color-accent-dim)]" />
          <span class="font-mono">{h}</span>
        </li>
      ))
    }
  </ul>
</a>
