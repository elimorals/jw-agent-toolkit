---
// Persistent disclaimer. By design it is the very first thing on the page,
// not buried in a footer modal — that's how we honor the "no es oficial"
// commitment without making the rest of the UI apologetic.
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
---

<div
  class="relative z-50 border-b border-[var(--color-line-subtle)] bg-[var(--color-surface-1)]/95 backdrop-blur supports-[backdrop-filter]:bg-[var(--color-surface-1)]/70"
>
  <div
    class="mx-auto flex max-w-7xl flex-wrap items-center justify-center gap-x-3 gap-y-1 px-4 py-2 text-center text-[11px] tracking-wide text-[var(--color-ink-tertiary)] sm:text-[12px]"
  >
    <span
      class="inline-flex items-center gap-1.5 rounded-[var(--radius-chip)] border border-[var(--color-warm-dim)]/40 bg-[var(--color-warm-dim)]/15 px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--color-warm)] sm:text-[11px]"
    >
      <svg
        viewBox="0 0 24 24"
        class="size-3"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 9v4" />
        <path d="M12 17h.01" />
        <path
          d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"
        />
      </svg>
      {isEn ? "Independent Project" : "Proyecto independiente"}
    </span>
    <span class="font-body">
      {isEn 
        ? "Not affiliated with, sponsored by, or endorsed by the Watch Tower Bible and Tract Society or Jehovah's Witnesses."
        : "No afiliado, patrocinado ni avalado por la Watch Tower Bible and Tract Society o Jehovah's Witnesses."}
    </span>
  </div>
</div>
